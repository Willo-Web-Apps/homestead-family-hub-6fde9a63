---
import Base from '../layouts/Base.astro';
---
<Base
  title="Hearthstead — Where Families Put Down Roots"
  description="Hearthstead guides families through every step of the homesteading journey — from first garden beds to full pantries — together."
>

  <!-- ============================================================
       HERO — Immersive, atmospheric, editorial storytelling
       Full-bleed, golden-hour gradient with grain texture
       ============================================================ -->
  <section class="relative min-h-[95vh] flex items-center overflow-hidden hero-bg noise-overlay">

    <!-- Drifting botanical orb — upper right, very subtle -->
    <div
      class="absolute top-[-8%] right-[-5%] w-[520px] h-[520px] rounded-full pointer-events-none animate-drift"
      style="background: radial-gradient(circle at 40% 40%, oklch(0.54 0.085 140 / 0.13) 0%, transparent 65%); filter: blur(40px);"
      aria-hidden="true"
    ></div>

    <!-- Warm amber glow — lower left -->
    <div
      class="absolute bottom-[-10%] left-[-8%] w-[480px] h-[480px] rounded-full pointer-events-none animate-pulse-soft"
      style="background: radial-gradient(circle at 55% 55%, oklch(0.60 0.110 55 / 0.16) 0%, transparent 65%); filter: blur(50px);"
      aria-hidden="true"
    ></div>

    <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-28 md:py-40 w-full">
      <div class="max-w-4xl">

        <!-- Eyebrow label with botanical rule -->
        <div class="animate-fade-in flex items-center gap-4 mb-8">
          <span class="block w-8 h-px bg-accent-500 opacity-70"></span>
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-accent-500 font-body">
            Family Homesteading — Made Joyful &amp; Practical
          </p>
        </div>

        <!-- Main headline — dramatic serif, generous scale -->
        <h1 class="animate-slide-up font-display leading-[1.03] tracking-tight text-surface-900" style="font-size: clamp(3.2rem, 9vw, 7.5rem); font-weight: 600;">
          Grow Food,<br>
          <em class="font-normal italic" style="color: oklch(0.36 0.080 140);">Build Skills,</em><br>
          Raise Capable Kids
        </h1>

        <!-- Subheadline -->
        <p class="animate-slide-up delay-200 mt-8 text-xl md:text-2xl text-surface-800 max-w-2xl leading-relaxed font-body" style="font-weight: 400; color: oklch(0.32 0.032 76);">
          Hearthstead guides families through every step of the homesteading journey — from first garden beds to full pantries — <em>together.</em>
        </p>

        <!-- CTAs -->
        <div class="animate-slide-up delay-300 mt-12 flex flex-col sm:flex-row gap-4 items-start">
          <a
            href="#cta"
            class="inline-block px-9 py-4 font-semibold rounded-full transition-all duration-200 font-body text-base"
            style="background-color: oklch(0.36 0.080 140); color: oklch(0.97 0.012 85); letter-spacing: 0.01em;"
            onmouseover="this.style.backgroundColor='oklch(0.28 0.068 140)'"
            onmouseout="this.style.backgroundColor='oklch(0.36 0.080 140)'"
          >
            Start My Family's Journey
          </a>
          <a
            href="#story"
            class="inline-flex items-center gap-2.5 px-9 py-4 font-semibold rounded-full border transition-all duration-200 font-body text-base"
            style="border-color: oklch(0.36 0.080 140 / 0.35); color: oklch(0.36 0.080 140);"
            onmouseover="this.style.borderColor='oklch(0.36 0.080 140)'; this.style.backgroundColor='oklch(0.36 0.080 140 / 0.06)'"
            onmouseout="this.style.borderColor='oklch(0.36 0.080 140 / 0.35)'; this.style.backgroundColor='transparent'"
          >
            Read Our Story
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        </div>

        <!-- Social proof -->
        <div class="animate-fade-in delay-500 mt-10 flex items-center gap-4">
          <!-- Avatar stack (decorative) -->
          <div class="flex -space-x-2.5" aria-hidden="true">
            <div class="w-9 h-9 rounded-full border-2 flex items-center justify-center text-xs font-semibold" style="border-color: oklch(0.97 0.012 85); background: oklch(0.84 0.048 140); color: oklch(0.36 0.080 140);">M</div>
            <div class="w-9 h-9 rounded-full border-2 flex items-center justify-center text-xs font-semibold" style="border-color: oklch(0.97 0.012 85); background: oklch(0.84 0.078 62); color: oklch(0.50 0.110 52);">J</div>
            <div class="w-9 h-9 rounded-full border-2 flex items-center justify-center text-xs font-semibold" style="border-color: oklch(0.97 0.012 85); background: oklch(0.93 0.025 140); color: oklch(0.36 0.080 140);">R</div>
            <div class="w-9 h-9 rounded-full border-2 flex items-center justify-center text-xs font-semibold" style="border-color: oklch(0.97 0.012 85); background: oklch(0.91 0.020 82); color: oklch(0.28 0.030 75);">+</div>
          </div>
          <p class="text-sm font-body" style="color: oklch(0.40 0.028 76);">
            Join <strong style="color: oklch(0.28 0.030 75); font-weight: 600;">4,200+ families</strong> already growing together — no acres of land required.
          </p>
        </div>
      </div>
    </div>

    <!-- Bottom fade into story section -->
    <div class="absolute bottom-0 left-0 right-0 h-28 pointer-events-none z-10" style="background: linear-gradient(to bottom, transparent, oklch(0.96 0.015 85));"></div>

    <!-- Decorative serif letterform — bottom right, very large, partially cropped -->
    <div
      class="absolute bottom-[-4rem] right-[-2rem] select-none pointer-events-none opacity-[0.045] font-display leading-none"
      style="font-size: 28rem; font-weight: 700; color: oklch(0.36 0.080 140); z-index: 1; font-family: var(--font-display);"
      aria-hidden="true"
    >H</div>
  </section>

  <!-- ============================================================
       ORGANIC WAVE DIVIDER 1 — into story
       ============================================================ -->
  <div class="overflow-hidden leading-[0]" style="background: oklch(0.96 0.015 85);" aria-hidden="true">
    <svg viewBox="0 0 1440 90" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full block" preserveAspectRatio="none" style="height:90px; display:block; margin-top:-2px;">
      <path d="M0,45 C200,85 400,15 620,50 C800,78 1000,10 1200,42 C1320,60 1400,30 1440,45 L1440,0 L0,0 Z" fill="oklch(0.96 0.015 85)"/>
    </svg>
  </div>

  <!-- ============================================================
       ORIGIN STORY — Why Hearthstead Exists
       Asymmetric editorial two-column layout
       ============================================================ -->
  <section id="story" class="section-py" style="background: oklch(0.96 0.015 85);">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_1fr] gap-16 lg:gap-24 items-center">

        <!-- Text column -->
        <div class="animate-slide-left">
          <div class="flex items-center gap-3 mb-6">
            <span class="block w-6 h-px" style="background: oklch(0.60 0.120 55);"></span>
            <p class="text-xs font-semibold uppercase tracking-[0.22em] font-body" style="color: oklch(0.60 0.120 55);">Our Story</p>
          </div>

          <h2 class="font-display font-semibold text-surface-900 leading-tight mb-8" style="font-size: clamp(2.4rem, 5.5vw, 4.2rem); line-height: 1.05;">
            Modern families are hungry<br>
            <em class="font-normal italic" style="color: oklch(0.36 0.080 140);">for something real.</em>
          </h2>

          <div class="space-y-5 leading-relaxed font-body" style="font-size: 1.1rem; color: oklch(0.32 0.030 76); line-height: 1.8;">
            <p>
              We didn't set out to homestead. We set out to eat a tomato grown by our own hands — and to let our children experience the quiet pride of harvesting something they'd planted from seed.
            </p>
            <p>
              But everywhere we looked, the resources were scattered: written for experienced farmers, solo adventurers, or people with five acres and two decades of free time. Nothing was built for a busy family in a suburban backyard, trying to find their footing one season at a time.
            </p>
            <p class="drop-cap">
              So we built Hearthstead — a home for families who want to grow food, preserve the harvest, and raise children who know where their dinner came from. Every guide, every skill, every community corner is designed with the whole family in mind.
            </p>
          </div>

          <!-- Pull quote -->
          <blockquote class="pull-quote mt-10 max-w-lg">
            "Children who grow things grow confidence. Families who work the soil together work through everything together."
          </blockquote>
        </div>

        <!-- Visual composition column — typographic sculpture -->
        <div class="relative flex items-center justify-center animate-slide-right">
          <!-- Large background "H" letterform — decorative magazine device -->
          <span
            class="absolute select-none pointer-events-none font-display leading-none"
            style="font-size: 20rem; font-weight: 700; color: oklch(0.84 0.048 140); opacity: 0.35; top: 50%; left: 50%; transform: translate(-50%, -50%); font-family: var(--font-display);"
            aria-hidden="true"
          >H</span>

          <div class="relative z-10 grid grid-cols-2 gap-4 w-full max-w-md">
            <!-- Stat 1 — families -->
            <div class="rounded-2xl p-6 shadow-sm border animate-slide-up delay-100" style="background: oklch(0.985 0.008 85); border-color: oklch(0.84 0.022 80 / 0.5);">
              <p class="font-display font-bold leading-none mb-2" style="font-size: 3.2rem; color: oklch(0.36 0.080 140);">4,200+</p>
              <p class="font-body leading-snug" style="font-size: 0.82rem; color: oklch(0.40 0.028 76);">Families growing together right now</p>
            </div>
            <!-- Stat 2 — accent block -->
            <div class="rounded-2xl p-6 shadow-sm animate-slide-up delay-200" style="background: oklch(0.60 0.120 55);">
              <p class="font-display font-bold leading-none mb-2" style="font-size: 3.2rem; color: oklch(0.985 0.008 85);">3 sq ft</p>
              <p class="font-body leading-snug" style="font-size: 0.82rem; color: oklch(0.985 0.008 85 / 0.82);">All the space you need to start your first family garden</p>
            </div>
            <!-- Stat 3 — wide green block -->
            <div class="col-span-2 rounded-2xl p-6 shadow-sm animate-slide-up delay-300" style="background: oklch(0.36 0.080 140);">
              <p class="font-display font-semibold leading-none mb-2" style="font-size: 1.8rem; color: oklch(0.985 0.008 85);">Every season, new roots.</p>
              <p class="font-body leading-snug" style="font-size: 0.85rem; color: oklch(0.985 0.008 85 / 0.78);">Step-by-step seasonal guides that grow with your family — from first sprouts to full pantry shelves.</p>
            </div>
            <!-- Tagline badge -->
            <div class="col-span-2 rounded-2xl p-5 border text-center animate-slide-up delay-400" style="background: oklch(0.91 0.020 82 / 0.6); border-color: oklch(0.84 0.022 80 / 0.4);">
              <p class="font-display text-lg italic" style="color: oklch(0.36 0.080 140 / 0.80);">
                "Where families put down roots."
              </p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ============================================================
       ORGANIC WAVE DIVIDER 2 — into How It Works
       ============================================================ -->
  <div class="overflow-hidden leading-[0]" style="background: oklch(0.985 0.008 85);" aria-hidden="true">
    <svg viewBox="0 0 1440 90" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full block" preserveAspectRatio="none" style="height:90px; display:block;">
      <path d="M0,0 C300,80 600,5 900,55 C1080,85 1260,15 1440,50 L1440,90 L0,90 Z" fill="oklch(0.91 0.020 82)"/>
    </svg>
  </div>

  <!-- ============================================================
       HOW IT WORKS — Three-season journey
       ============================================================ -->
  <section id="how-it-works" class="section-py" style="background: oklch(0.91 0.020 82);">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Section header -->
      <div class="text-center max-w-2xl mx-auto mb-20 animate-slide-up">
        <div class="flex items-center justify-center gap-3 mb-5">
          <span class="block w-6 h-px" style="background: oklch(0.60 0.120 55);"></span>
          <p class="text-xs font-semibold uppercase tracking-[0.22em] font-body" style="color: oklch(0.60 0.120 55);">Your Journey</p>
          <span class="block w-6 h-px" style="background: oklch(0.60 0.120 55);"></span>
        </div>
        <h2 class="font-display font-semibold text-surface-900 leading-tight" style="font-size: clamp(2.2rem, 5vw, 3.8rem);">
          Three seasons.<br>
          <em class="font-normal italic" style="color: oklch(0.36 0.080 140);">One family. A life you'll love.</em>
        </h2>
        <p class="mt-5 font-body leading-relaxed" style="font-size: 1.1rem; color: oklch(0.38 0.028 76);">
          You don't need experience — just the willingness to start. Hearthstead meets you where you are and grows with you.
        </p>
      </div>

      <!-- Three steps -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-10">

        <!-- Step 1 — Start Your Garden -->
        <div class="relative rounded-3xl p-8 lg:p-10 shadow-sm border overflow-hidden animate-slide-up delay-100 group" style="background: oklch(0.985 0.008 85); border-color: oklch(0.84 0.022 80 / 0.55); transition: box-shadow 0.25s ease;">
          <!-- Large step numeral -->
          <span
            class="absolute top-3 right-5 font-display font-bold select-none pointer-events-none leading-none"
            style="font-size: 8rem; color: oklch(0.84 0.048 140); opacity: 0.45;"
            aria-hidden="true"
          >1</span>

          <!-- Icon -->
          <div class="relative z-10 w-12 h-12 rounded-2xl flex items-center justify-center mb-6" style="background: oklch(0.93 0.025 140);">
            <svg class="w-6 h-6" style="color: oklch(0.36 0.080 140);" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
              <!-- Seedling / sprout icon -->
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 22V12m0 0C12 7 7 4 3 6c0 4 3 7 9 6zm0 0c0-5 5-8 9-6 0 4-3 7-9 6z"/>
            </svg>
          </div>

          <h3 class="relative z-10 font-display font-semibold text-surface-900 mb-3 leading-snug" style="font-size: 1.6rem;">
            Start Your Garden
          </h3>
          <p class="relative z-10 font-body leading-relaxed" style="font-size: 0.97rem; color: oklch(0.38 0.028 76);">
            Begin with just a few containers or a raised bed. Our family-first guides walk you through selecting seeds, building soil, and getting kids excited to dig in — no matter your outdoor space.
          </p>
          <div class="relative z-10 mt-6">
            <a href="#cta" class="inline-flex items-center gap-1.5 text-sm font-semibold font-body group-hover:gap-3 transition-all duration-200" style="color: oklch(0.36 0.080 140);">
              First Garden Guide
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
          </div>
        </div>

        <!-- Step 2 — Build Your Skills (accent/inverted card) -->
        <div class="relative rounded-3xl p-8 lg:p-10 shadow-sm overflow-hidden animate-slide-up delay-200 group" style="background: oklch(0.36 0.080 140); transition: box-shadow 0.25s ease;">
          <span
            class="absolute top-3 right-5 font-display font-bold select-none pointer-events-none leading-none"
            style="font-size: 8rem; color: oklch(0.985 0.008 85); opacity: 0.09;"
            aria-hidden="true"
          >2</span>

          <div class="relative z-10 w-12 h-12 rounded-2xl flex items-center justify-center mb-6" style="background: oklch(0.985 0.008 85 / 0.18);">
            <svg class="w-6 h-6" style="color: oklch(0.97 0.012 85);" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
              <!-- Book/skill icon -->
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
            </svg>
          </div>

          <h3 class="relative z-10 font-display font-semibold mb-3 leading-snug" style="font-size: 1.6rem; color: oklch(0.985 0.008 85);">
            Build Your Skills
          </h3>
          <p class="relative z-10 font-body leading-relaxed" style="font-size: 0.97rem; color: oklch(0.97 0.012 85 / 0.80);">
            From composting and seed-saving to bread baking and chicken-keeping — learn practical homestead skills as a family. Every lesson teaches parents and children side by side.
          </p>
          <div class="relative z-10 mt-6">
            <a href="#cta" class="inline-flex items-center gap-1.5 text-sm font-semibold font-body group-hover:gap-3 transition-all duration-200" style="color: oklch(0.97 0.012 85);">
              Skill Library
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
          </div>
        </div>

        <!-- Step 3 — Stock Your Pantry -->
        <div class="relative rounded-3xl p-8 lg:p-10 shadow-sm border overflow-hidden animate-slide-up delay-300 group" style="background: oklch(0.985 0.008 85); border-color: oklch(0.84 0.022 80 / 0.55); transition: box-shadow 0.25s ease;">
          <span
            class="absolute top-3 right-5 font-display font-bold select-none pointer-events-none leading-none"
            style="font-size: 8rem; color: oklch(0.84 0.078 62); opacity: 0.50;"
            aria-hidden="true"
          >3</span>

          <div class="relative z-10 w-12 h-12 rounded-2xl flex items-center justify-center mb-6" style="background: oklch(0.93 0.040 65);">
            <svg class="w-6 h-6" style="color: oklch(0.50 0.110 52);" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
              <!-- Jar/preserve icon -->
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/>
            </svg>
          </div>

          <h3 class="relative z-10 font-display font-semibold text-surface-900 mb-3 leading-snug" style="font-size: 1.6rem;">
            Stock Your Pantry
          </h3>
          <p class="relative z-10 font-body leading-relaxed" style="font-size: 0.97rem; color: oklch(0.38 0.028 76);">
            Preserve your harvest with confidence. Canning, fermenting, dehydrating, and root cellaring — straightforward guides that transform summer's abundance into food security all winter long.
          </p>
          <div class="relative z-10 mt-6">
            <a href="#cta" class="inline-flex items-center gap-1.5 text-sm font-semibold font-body group-hover:gap-3 transition-all duration-200" style="color: oklch(0.60 0.120 55);">
              Preservation Guides
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ============================================================
       ORGANIC WAVE DIVIDER 3 — into Values
       ============================================================ -->
  <div class="overflow-hidden leading-[0]" style="background: oklch(0.96 0.015 85);" aria-hidden="true">
    <svg viewBox="0 0 1440 90" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full block" preserveAspectRatio="none" style="height:90px; display:block;">
      <path d="M0,25 C180,75 400,5 700,45 C900,72 1100,12 1300,38 C1380,52 1420,32 1440,40 L1440,0 L0,0 Z" fill="oklch(0.91 0.020 82)"/>
    </svg>
  </div>

  <!-- ============================================================
       VALUES / WHO IT'S FOR — Built for families
       ============================================================ -->
  <section id="values" class="section-py" style="background: oklch(0.96 0.015 85);">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Section header -->
      <div class="text-center max-w-2xl mx-auto mb-20 animate-slide-up">
        <div class="flex items-center justify-center gap-3 mb-5">
          <span class="block w-6 h-px" style="background: oklch(0.60 0.120 55);"></span>
          <p class="text-xs font-semibold uppercase tracking-[0.22em] font-body" style="color: oklch(0.60 0.120 55);">Our Principles</p>
          <span class="block w-6 h-px" style="background: oklch(0.60 0.120 55);"></span>
        </div>
        <h2 class="font-display font-semibold text-surface-900 leading-tight" style="font-size: clamp(2.2rem, 5vw, 3.8rem);">
          Built for <em class="font-normal italic" style="color: oklch(0.36 0.080 140);">families</em> —<br>
          not just homesteaders.
        </h2>
        <p class="mt-5 font-body leading-relaxed" style="font-size: 1.1rem; color: oklch(0.38 0.028 76);">
          Everything at Hearthstead is designed with the whole family unit in mind — parents and children learning the same skills, side by side.
        </p>
      </div>

      <!-- Values grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-16">

        <!-- Value 1 — Suburban-Friendly -->
        <div class="rounded-2xl p-7 border animate-slide-up delay-100" style="background: oklch(0.985 0.008 85); border-color: oklch(0.84 0.022 80 / 0.5);">
          <div class="w-11 h-11 rounded-xl flex items-center justify-center mb-5" style="background: oklch(0.93 0.025 140);">
            <svg class="w-5 h-5" style="color: oklch(0.36 0.080 140);" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
            </svg>
          </div>
          <h3 class="font-display font-semibold text-surface-900 mb-2" style="font-size: 1.25rem;">Suburban-Friendly</h3>
          <p class="font-body leading-relaxed" style="font-size: 0.9rem; color: oklch(0.40 0.028 76);">
            You don't need acreage. Our guides work for a 10×10 yard, a patio, or a sunny windowsill.
          </p>
        </div>

        <!-- Value 2 — Family-First -->
        <div class="rounded-2xl p-7 border animate-slide-up delay-200" style="background: oklch(0.985 0.008 85); border-color: oklch(0.84 0.022 80 / 0.5);">
          <div class="w-11 h-11 rounded-xl flex items-center justify-center mb-5" style="background: oklch(0.93 0.040 65);">
