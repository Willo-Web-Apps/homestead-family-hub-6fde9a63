---
<header class="sticky top-0 z-50 border-b border-surface-200/60 bg-surface-50/90 backdrop-blur-md">
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
    <!-- Logo / Wordmark -->
    <a href="/" class="flex items-center gap-2.5 group">
      <!-- Leaf icon -->
      <svg class="w-7 h-7 text-brand-500 flex-shrink-0" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M5 23C5 23 7 14 14 9C21 4 24 5 24 5C24 5 23 10 18 15C13 20 5 23 5 23Z" fill="currentColor" fill-opacity="0.85"/>
        <path d="M5 23C8 20 11 17 13 14" stroke="oklch(0.96 0.015 85)" stroke-width="1.2" stroke-linecap="round"/>
      </svg>
      <span class="font-display text-xl font-semibold tracking-wide text-surface-900">Hearthstead</span>
    </a>

    <!-- Nav links (desktop) -->
    <div class="hidden md:flex items-center gap-7">
      <a href="#story" class="text-sm font-medium text-surface-800/70 hover:text-brand-500 transition-colors duration-150">Our Story</a>
      <a href="#how-it-works" class="text-sm font-medium text-surface-800/70 hover:text-brand-500 transition-colors duration-150">How It Works</a>
      <a href="#values" class="text-sm font-medium text-surface-800/70 hover:text-brand-500 transition-colors duration-150">Community</a>
      <a href="#cta" class="text-sm font-semibold bg-brand-500 text-surface-50 px-5 py-2.5 rounded-full hover:bg-brand-600 transition-colors duration-150">
        Start Your Journey
      </a>
    </div>

    <!-- Mobile menu button (decorative — Polish Phase can add JS) -->
    <button class="md:hidden p-2 text-surface-800/70 hover:text-surface-900" aria-label="Menu">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
  </nav>
</header>
